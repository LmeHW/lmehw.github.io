<%
if (theme.index.slogan.enable) {
  page.subtitle = theme.index.slogan.text || config.subtitle || ''
}
page.banner_img = theme.index.banner_img
page.banner_img_height = theme.index.banner_img_height
page.banner_mask_alpha = theme.index.banner_mask_alpha
%>

<% page.posts.each(function (post) { %>
  <div class="row mx-auto index-card">
    <% var post_url = url_for(post.path), index_img = post.index_img || theme.post.default_index_img %>
    <% if (index_img) { %>
      <div class="col-12 col-md-4 m-auto index-img">
        <a href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
          <img src="<%= url_for(index_img) %>" alt="<%= post.title %>">
        </a>
      </div>
    <% } %>
    <article class="col-12 col-md-<%= index_img ? '8' : '12' %> mx-auto index-info">
      <h2 class="index-header">
        <% if (theme.index.post_sticky && theme.index.post_sticky.enable && post.sticky > 0) { %>
          <i class="index-pin <%= theme.index.post_sticky && theme.index.post_sticky.icon %>" title="Pin on top"></i>
        <% } %>
        <a href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
          <%= post.title %>
        </a>
      </h2>

      <% var excerpt = post.description || post.excerpt || (theme.index.auto_excerpt.enable && !post.encrypt && post.content) %>
      <a class="index-excerpt <%= index_img ? '' : 'index-excerpt__noimg' %>" href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
        <div>
          <%- strip_html(excerpt).substring(0, 200).trim().replace(/\n/g, ' ') %>
        </div>
      </a>

      <div class="index-btm post-metas">
        <% if (theme.index.post_meta.date) { %>
          <div class="post-meta mr-3">
            <i class="iconfont icon-date"></i>
            <time datetime="<%= full_date(post.date, 'YYYY-MM-DD HH:mm') %>" pubdate>
              <%- date(post.date, config.date_format) %>
            </time>
          </div>
        <% } %>
        <% if (theme.index.post_meta.category && post.categories.length > 0) { %>
          <div class="post-meta mr-3 d-flex align-items-center">
            <i class="iconfont icon-category"></i>
            <%- partial('_partials/category-chains', { categories: post.categories, limit: 1 }) %>
          </div>
        <% } %>
        <% if (theme.index.post_meta.tag && post.tags.length > 0) { %>
          <div class="post-meta">
            <i class="iconfont icon-tags"></i>
            <% post.tags.each(function(tag){ %>
              <a href="<%= url_for(tag.path) %>">#<%- tag.name %></a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </article>
  </div>
<% }) %>

<%- partial('_partials/paginator') %>

<style>
.home-explore {
  margin-top: 3.25rem;
}

.home-explore-heading {
  font-size: 1.8rem;
  font-weight: 700;
  margin: 0 0 0.65rem;
  color: var(--text-color, #2f4154);
}

.home-explore-intro {
  margin: 0 0 1.1rem;
  color: var(--sec-text-color, #5c6b77);
  line-height: 1.75;
}

.home-explore-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.9rem;
  margin: 0 0 1.35rem;
}

.home-explore-link {
  color: var(--link-color, #1d4ed8);
  text-decoration: none;
}

.home-explore-link:hover {
  text-decoration: underline;
}

.home-explore-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-bottom: 1rem;
}

.ex-pill {
  appearance: none;
  border: 1px solid var(--line-color, #d0d7de);
  background: var(--board-bg-color, #fff);
  color: var(--sec-text-color, #5c6b77);
  border-radius: 999px;
  padding: 0.36rem 0.88rem;
  font-size: 0.9rem;
  line-height: 1.1;
  cursor: pointer;
  transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
}

.ex-pill:hover {
  border-color: var(--link-color, #1d4ed8);
  color: var(--link-color, #1d4ed8);
}

.ex-pill.is-active {
  background: var(--link-color, #1d4ed8);
  border-color: var(--link-color, #1d4ed8);
  color: #fff;
}

.ex-pill:focus-visible {
  outline: 2px solid var(--link-hover-color, #1e40af);
  outline-offset: 2px;
}

.ex-pill-count {
  opacity: 0.7;
}

.home-explore-status {
  margin: 0 0 1rem;
  color: var(--sec-text-color, #5c6b77);
  font-size: 0.95rem;
}

.home-explore-results {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.ex-card {
  display: block;
  border: 1px solid var(--line-color, #d0d7de);
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  background: var(--board-bg-color, #fff);
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.ex-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
  border-color: var(--link-color, #1d4ed8);
}

.ex-card.is-hidden {
  display: none;
}

.ex-card-img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}

.ex-card-body {
  padding: 0.82rem 0.92rem 0.9rem;
}

.ex-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.6rem;
  margin-bottom: 0.52rem;
}

.ex-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  font-size: 0.72rem;
  line-height: 1;
  font-weight: 600;
  letter-spacing: 0.01em;
  padding: 0.28rem 0.56rem;
}

.ex-badge-blog {
  background: rgba(29, 78, 216, 0.12);
  color: #1d4ed8;
}

.ex-badge-project {
  background: rgba(15, 23, 42, 0.12);
  color: #0f172a;
}

.ex-card-date {
  font-size: 0.74rem;
  color: var(--sec-text-color, #5c6b77);
}

.ex-card-title {
  margin: 0 0 0.4rem;
  font-size: 1rem;
  line-height: 1.45;
  color: var(--text-color, #2f4154);
}

.ex-card-desc {
  margin: 0 0 0.62rem;
  font-size: 0.88rem;
  line-height: 1.62;
  color: var(--sec-text-color, #5c6b77);
}

.ex-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.ex-card-tag {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  border: 1px solid var(--line-color, #d0d7de);
  padding: 0.14rem 0.48rem;
  font-size: 0.72rem;
  color: var(--sec-text-color, #5c6b77);
}

@media (max-width: 767.98px) {
  .home-explore {
    margin-top: 2.4rem;
  }

  .home-explore-results {
    grid-template-columns: 1fr;
  }
}

@media (min-width: 768px) and (max-width: 991.98px) {
  .home-explore-results {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
</style>

<%
  var explorePosts = site.posts.sort('-date');
  var rawExploreProjects = site.data.home_explore_projects || [];
  var exploreProjects = rawExploreProjects.map(function(project) {
    var normalizedTags = Array.isArray(project.tags) ? project.tags : [];
    return {
      title: project.title || 'Untitled Project',
      url: project.url ? url_for(project.url) : url_for('/projects/'),
      img: project.img ? url_for(project.img) : '',
      date: project.date || '',
      desc: project.desc || '',
      tags: normalizedTags
    };
  });
  var reservedExploreTags = { blog: true, projects: true };
%>

<section class="home-explore">
  <h2 class="home-explore-heading">Explore</h2>
  <p class="home-explore-intro">Browse all posts and projects by tag. Click a tag to filter.</p>

  <div class="home-explore-links">
    <a class="home-explore-link" href="<%= url_for('/tags/') %>">All Tags</a>
    <a class="home-explore-link" href="<%= url_for('/projects/') %>">All Projects</a>
  </div>

  <div class="home-explore-tags" id="home-explore-tags">
    <button class="ex-pill is-active" type="button" data-tag="" data-label="All">
      All <span class="ex-pill-count">· <%= explorePosts.length + exploreProjects.length %></span>
    </button>
    <button class="ex-pill" type="button" data-tag="blog" data-label="blog">
      blog <span class="ex-pill-count">· <%= explorePosts.length %></span>
    </button>
    <button class="ex-pill" type="button" data-tag="projects" data-label="projects">
      projects <span class="ex-pill-count">· <%= exploreProjects.length %></span>
    </button>
    <% site.tags.sort('name').each(function(tag) { %>
      <% var loweredTagName = tag.name.toLowerCase() %>
      <% if (reservedExploreTags[loweredTagName] !== true) { %>
        <button class="ex-pill" type="button" data-tag="<%= encodeURIComponent(tag.name) %>" data-label="<%= tag.name %>">
          <%= tag.name %> <span class="ex-pill-count">· <%= tag.length %></span>
        </button>
      <% } %>
    <% }) %>
  </div>

  <p class="home-explore-status" id="home-explore-status">Showing all items.</p>

  <div class="home-explore-results" id="home-explore-results">
    <% explorePosts.each(function(post) { %>
      <% var explorePostUrl = url_for(post.path) %>
      <% var explorePostImg = post.index_img || theme.post.default_index_img %>
      <% var explorePostTags = ['blog'].concat(post.tags.map(function(tag) { return tag.name })) %>
      <a class="ex-card" href="<%= explorePostUrl %>" target="<%- theme.index.post_url_target %>" data-tags="<%= explorePostTags.map(function(tagName) { return encodeURIComponent(tagName) }).join(' ') %>">
        <% if (explorePostImg) { %>
          <img class="ex-card-img" src="<%= url_for(explorePostImg) %>" alt="<%= post.title %>" loading="lazy">
        <% } %>
        <div class="ex-card-body">
          <div class="ex-card-top">
            <span class="ex-badge ex-badge-blog">Blog</span>
            <span class="ex-card-date"><%- date(post.date, config.date_format) %></span>
          </div>
          <h3 class="ex-card-title"><%= post.title %></h3>
          <% var explorePostExcerpt = post.description || post.excerpt || (theme.index.auto_excerpt.enable && post.encrypt !== true && post.content) %>
          <p class="ex-card-desc">
            <%- strip_html(explorePostExcerpt).substring(0, 140).trim().replace(/\n/g, ' ') %>
          </p>
          <div class="ex-card-tags">
            <span class="ex-card-tag">blog</span>
            <% post.tags.limit(3).each(function(tag){ %>
              <span class="ex-card-tag"><%- tag.name %></span>
            <% }) %>
          </div>
        </div>
      </a>
    <% }) %>

    <% exploreProjects.forEach(function(project) { %>
      <a class="ex-card" href="<%= project.url %>" data-tags="<%= project.tags.map(function(tagName) { return encodeURIComponent(tagName) }).join(' ') %>">
        <% if (project.img) { %>
          <img class="ex-card-img" src="<%= project.img %>" alt="<%= project.title %>" loading="lazy">
        <% } %>
        <div class="ex-card-body">
          <div class="ex-card-top">
            <span class="ex-badge ex-badge-project">Project</span>
            <span class="ex-card-date"><%= project.date %></span>
          </div>
          <h3 class="ex-card-title"><%= project.title %></h3>
          <p class="ex-card-desc"><%= project.desc %></p>
          <div class="ex-card-tags">
            <% project.tags.slice(0, 4).forEach(function(tagName) { %>
              <span class="ex-card-tag"><%= tagName %></span>
            <% }) %>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<script>
  (function() {
    var tagBar = document.getElementById('home-explore-tags');
    var status = document.getElementById('home-explore-status');
    var cards = Array.prototype.slice.call(document.querySelectorAll('#home-explore-results .ex-card'));

    if (tagBar === null || status === null || cards.length === 0) return;

    function decodeTag(tag) {
      if (tag === undefined || tag === null || tag === '') return '';
      try {
        return decodeURIComponent(tag);
      } catch (error) {
        return tag;
      }
    }

    function applyFilter(tagValue, label) {
      var visibleCount = 0;
      var activeLabel = label || decodeTag(tagValue) || 'All';

      Array.prototype.forEach.call(tagBar.querySelectorAll('.ex-pill'), function(button) {
        button.classList.toggle('is-active', button.dataset.tag === tagValue);
      });

      cards.forEach(function(card) {
        var tags = (card.dataset.tags || '').split(' ').filter(Boolean);
        var show = (tagValue === '' || tags.indexOf(tagValue) !== -1);
        card.classList.toggle('is-hidden', show === false);
        if (show === true) visibleCount += 1;
      });

      if (tagValue === '') {
        status.textContent = 'Showing all items (' + visibleCount + ').';
        return;
      }

      status.textContent = visibleCount > 0
        ? 'Showing ' + visibleCount + ' item' + (visibleCount > 1 ? 's' : '') + ' tagged with "' + activeLabel + '".'
        : 'No items found for "' + activeLabel + '".';
    }

    tagBar.addEventListener('click', function(event) {
      var button = event.target.closest('.ex-pill');
      if (button === null) return;
      applyFilter(button.dataset.tag || '', button.dataset.label || '');
    });

    applyFilter('', 'All');
  })();
</script>
