<%
if (theme.index.slogan.enable) {
  page.subtitle = theme.index.slogan.text || config.subtitle || ''
}
page.banner_img = theme.index.banner_img
page.banner_img_height = theme.index.banner_img_height
page.banner_mask_alpha = theme.index.banner_mask_alpha
%>

<% page.posts.each(function (post) { %>
  <div class="row mx-auto index-card">
    <% var post_url = url_for(post.path), index_img = post.index_img || theme.post.default_index_img %>
    <% if (index_img) { %>
      <div class="col-12 col-md-4 m-auto index-img">
        <a href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
          <img src="<%= url_for(index_img) %>" alt="<%= post.title %>">
        </a>
      </div>
    <% } %>
    <article class="col-12 col-md-<%= index_img ? '8' : '12' %> mx-auto index-info">
      <h2 class="index-header">
        <% if (theme.index.post_sticky && theme.index.post_sticky.enable && post.sticky > 0) { %>
          <i class="index-pin <%= theme.index.post_sticky && theme.index.post_sticky.icon %>" title="Pin on top"></i>
        <% } %>
        <a href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
          <%= post.title %>
        </a>
      </h2>

      <% var excerpt = post.description || post.excerpt || (theme.index.auto_excerpt.enable && !post.encrypt && post.content) %>
      <a class="index-excerpt <%= index_img ? '' : 'index-excerpt__noimg' %>" href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
        <div>
          <%- strip_html(excerpt).substring(0, 200).trim().replace(/\n/g, ' ') %>
        </div>
      </a>

      <div class="index-btm post-metas">
        <% if (theme.index.post_meta.date) { %>
          <div class="post-meta mr-3">
            <i class="iconfont icon-date"></i>
            <time datetime="<%= full_date(post.date, 'YYYY-MM-DD HH:mm') %>" pubdate>
              <%- date(post.date, config.date_format) %>
            </time>
          </div>
        <% } %>
        <% if (theme.index.post_meta.category && post.categories.length > 0) { %>
          <div class="post-meta mr-3 d-flex align-items-center">
            <i class="iconfont icon-category"></i>
            <%- partial('_partials/category-chains', { categories: post.categories, limit: 1 }) %>
          </div>
        <% } %>
        <% if (theme.index.post_meta.tag && post.tags.length > 0) { %>
          <div class="post-meta">
            <i class="iconfont icon-tags"></i>
            <% post.tags.each(function(tag){ %>
              <a href="<%= url_for(tag.path) %>">#<%- tag.name %></a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </article>
  </div>
<% }) %>

<%- partial('_partials/paginator') %>

<style>
.home-explore {
  margin-top: 3rem;
}

.home-explore-heading {
  font-size: 1.6rem;
  font-weight: 600;
  line-height: 1.35;
  margin: 0 0 0.75rem;
  color: var(--text-color, #2f4154);
}

.home-explore-intro {
  margin: 0 0 1rem;
  color: var(--sec-text-color, #5c6b77);
  line-height: 1.8;
}

.home-explore-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.85rem;
  margin: 0 0 1.25rem;
}

.home-explore-link {
  color: var(--link-color, #1d4ed8);
  text-decoration: none;
}

.home-explore-link:hover {
  text-decoration: underline;
}

.home-explore-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-bottom: 1.5rem;
}

.home-explore-tag {
  appearance: none;
  border: 1px solid var(--line-color, #d0d7de);
  background: transparent;
  color: var(--text-color, #2f4154);
  border-radius: 999px;
  padding: 0.38rem 0.95rem;
  font-size: 0.9rem;
  line-height: 1.2;
  cursor: pointer;
  transition: border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
}

.home-explore-tag:hover,
.home-explore-tag.is-active {
  background: transparent;
  border-color: var(--link-hover-color, #1e40af);
  color: var(--link-hover-color, #1e40af);
}

.home-explore-tag:focus-visible {
  outline: 2px solid var(--link-hover-color, #1e40af);
  outline-offset: 2px;
}

.home-explore-tag-count {
  opacity: 0.7;
}

.home-explore-status {
  margin: 0 0 1rem;
  color: var(--sec-text-color, #5c6b77);
  font-size: 0.95rem;
}

.home-explore-results .index-card {
  transition: opacity 0.18s ease;
}

.home-explore-results .index-card.is-hidden {
  display: none;
}

@media (max-width: 767.98px) {
  .home-explore {
    margin-top: 2.4rem;
  }
}
</style>

<section class="home-explore">
  <h2 class="home-explore-heading">Browse by Tag</h2>
  <p class="home-explore-intro">Click a tag to filter posts directly on this page.</p>

  <div class="home-explore-links">
    <a class="home-explore-link" href="<%= url_for('/tags/') %>">All Tags</a>
    <a class="home-explore-link" href="<%= url_for('/categories/') %>">Browse Categories</a>
  </div>

  <div class="home-explore-tags" id="home-explore-tags">
    <button class="home-explore-tag is-active" type="button" data-tag="">
      All <span class="home-explore-tag-count">· <%= site.posts.length %></span>
    </button>
    <% site.tags.sort('name').each(function(tag) { %>
      <button class="home-explore-tag" type="button" data-tag="<%= encodeURIComponent(tag.name) %>">
        <%= tag.name %> <span class="home-explore-tag-count">· <%= tag.length %></span>
      </button>
    <% }) %>
  </div>

  <p class="home-explore-status" id="home-explore-status">Showing all posts.</p>

  <div class="home-explore-results" id="home-explore-results">
    <% site.posts.sort('-date').each(function(post) { %>
      <% var filtered_post_url = url_for(post.path), filtered_index_img = post.index_img || theme.post.default_index_img %>
      <div class="row mx-auto index-card" data-tags="<%= post.tags.map(function(tag) { return encodeURIComponent(tag.name) }).join(' ') %>">
        <% if (filtered_index_img) { %>
          <div class="col-12 col-md-4 m-auto index-img">
            <a href="<%= filtered_post_url %>" target="<%- theme.index.post_url_target %>">
              <img src="<%= url_for(filtered_index_img) %>" alt="<%= post.title %>">
            </a>
          </div>
        <% } %>
        <article class="col-12 col-md-<%= filtered_index_img ? '8' : '12' %> mx-auto index-info">
          <h2 class="index-header">
            <a href="<%= filtered_post_url %>" target="<%- theme.index.post_url_target %>">
              <%= post.title %>
            </a>
          </h2>

          <% var filtered_excerpt = post.description || post.excerpt || (theme.index.auto_excerpt.enable && !post.encrypt && post.content) %>
          <a class="index-excerpt <%= filtered_index_img ? '' : 'index-excerpt__noimg' %>" href="<%= filtered_post_url %>" target="<%- theme.index.post_url_target %>">
            <div>
              <%- strip_html(filtered_excerpt).substring(0, 200).trim().replace(/\n/g, ' ') %>
            </div>
          </a>

          <div class="index-btm post-metas">
            <% if (theme.index.post_meta.date) { %>
              <div class="post-meta mr-3">
                <i class="iconfont icon-date"></i>
                <time datetime="<%= full_date(post.date, 'YYYY-MM-DD HH:mm') %>" pubdate>
                  <%- date(post.date, config.date_format) %>
                </time>
              </div>
            <% } %>
            <% if (theme.index.post_meta.category && post.categories.length > 0) { %>
              <div class="post-meta mr-3 d-flex align-items-center">
                <i class="iconfont icon-category"></i>
                <%- partial('_partials/category-chains', { categories: post.categories, limit: 1 }) %>
              </div>
            <% } %>
            <% if (theme.index.post_meta.tag && post.tags.length > 0) { %>
              <div class="post-meta">
                <i class="iconfont icon-tags"></i>
                <% post.tags.each(function(tag){ %>
                  <a href="<%= url_for(tag.path) %>">#<%- tag.name %></a>
                <% }) %>
              </div>
            <% } %>
          </div>
        </article>
      </div>
    <% }) %>
  </div>
</section>

<script>
  (function() {
    var tagBar = document.getElementById('home-explore-tags');
    var status = document.getElementById('home-explore-status');
    var cards = Array.prototype.slice.call(document.querySelectorAll('#home-explore-results .index-card'));

    if (!tagBar || !status || !cards.length) return;

    function decodeTag(encodedTag) {
      return encodedTag ? decodeURIComponent(encodedTag) : '';
    }

    function applyFilter(encodedTag) {
      var visibleCount = 0;
      var activeLabel = 'all posts';

      Array.prototype.forEach.call(tagBar.querySelectorAll('.home-explore-tag'), function(button) {
        button.classList.toggle('is-active', button.dataset.tag === encodedTag);
        if (button.dataset.tag === encodedTag && encodedTag) {
          activeLabel = decodeTag(encodedTag);
        }
      });

      cards.forEach(function(card) {
        var tags = card.dataset.tags ? card.dataset.tags.split(' ').filter(Boolean) : [];
        var show = !encodedTag || tags.indexOf(encodedTag) !== -1;
        card.classList.toggle('is-hidden', !show);
        if (show) visibleCount += 1;
      });

      if (!encodedTag) {
        status.textContent = 'Showing all posts.';
        return;
      }

      status.textContent = visibleCount
        ? 'Showing ' + visibleCount + ' post' + (visibleCount > 1 ? 's' : '') + ' tagged with "' + activeLabel + '".'
        : 'No posts found for "' + activeLabel + '".';
    }

    tagBar.addEventListener('click', function(event) {
      var button = event.target.closest('.home-explore-tag');
      if (!button) return;
      applyFilter(button.dataset.tag || '');
    });
  })();
</script>
