<%
if (theme.index.slogan.enable) {
  page.subtitle = theme.index.slogan.text || config.subtitle || ''
}
page.banner_img = theme.index.banner_img
page.banner_img_height = theme.index.banner_img_height
page.banner_mask_alpha = theme.index.banner_mask_alpha
%>

<style>
/* ── Home page — CSS variables (light mode) ─────────────────────── */
:root {
  --hi-text-primary:   #1e293b;
  --hi-text-secondary: #475569;
  --hi-text-date:      #64748b;
  --hi-accent:         #1d4ed8;
  --hi-accent-hover:   #1e40af;
  --hi-card-bg:        #f8fafc;
  --hi-card-border:    #e2e8f0;
  --hi-card-shadow:    rgba(0,0,0,0.04);
  --hi-card-shadow-hover: rgba(0,0,0,0.09);
  --hi-tag-bg:         #dbeafe;
  --hi-tag-color:      #1d4ed8;
  --hi-tag-border:     #bfdbfe;
  --hi-divider:        #e2e8f0;
  --hi-cat-badge-bg:   #f1f5f9;
  --hi-cat-badge-color:#475569;
}

/* ── Dark mode — OS preference ──────────────────────────────────── */
@media (prefers-color-scheme: dark) {
  html:not([data-user-color-scheme='light']) {
    --hi-text-primary:   #c4c6c9;
    --hi-text-secondary: #a7a9ad;
    --hi-text-date:      #6b7f92;
    --hi-accent:         #5b8ef0;
    --hi-accent-hover:   #7aaef5;
    --hi-card-bg:        #252d38;
    --hi-card-border:    #435266;
    --hi-card-shadow:    rgba(0,0,0,0.20);
    --hi-card-shadow-hover: rgba(0,0,0,0.30);
    --hi-tag-bg:         #364151;
    --hi-tag-color:      #5b8ef0;
    --hi-tag-border:     #435266;
    --hi-divider:        #435266;
    --hi-cat-badge-bg:   #2e3848;
    --hi-cat-badge-color:#a7a9ad;
  }
}

/* ── Dark mode — Fluid toggle ───────────────────────────────────── */
html[data-user-color-scheme='dark'] {
  --hi-text-primary:   #c4c6c9;
  --hi-text-secondary: #a7a9ad;
  --hi-text-date:      #6b7f92;
  --hi-accent:         #5b8ef0;
  --hi-accent-hover:   #7aaef5;
  --hi-card-bg:        #252d38;
  --hi-card-border:    #435266;
  --hi-card-shadow:    rgba(0,0,0,0.20);
  --hi-card-shadow-hover: rgba(0,0,0,0.30);
  --hi-tag-bg:         #364151;
  --hi-tag-color:      #5b8ef0;
  --hi-tag-border:     #435266;
  --hi-divider:        #435266;
  --hi-cat-badge-bg:   #2e3848;
  --hi-cat-badge-color:#a7a9ad;
}

/* ── Layout ─────────────────────────────────────────────────────── */
.hi-wrap {
  max-width: 720px;
  margin: 1.5rem auto 0;
  padding-bottom: 2rem;
}

/* ── Section header ─────────────────────────────────────────────── */
.hi-section { margin-bottom: 2.5rem; }

.hi-section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1.1rem;
  border-bottom: 1px solid var(--hi-divider);
  padding-bottom: 0.5rem;
}

.hi-section-title {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--hi-text-primary);
  margin: 0;
}

.hi-section-link {
  font-size: 0.8rem;
  color: var(--hi-accent);
  text-decoration: none;
  transition: color 0.15s;
}
.hi-section-link:hover { color: var(--hi-accent-hover); }

.hi-section-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.85rem;
  justify-content: flex-end;
}

/* ── Post cards ─────────────────────────────────────────────────── */
.hi-posts-list {
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
}

.hi-post-card {
  background: var(--hi-card-bg);
  border: 1px solid var(--hi-card-border);
  border-radius: 8px;
  padding: 1rem 1.25rem;
  box-shadow: 0 1px 3px var(--hi-card-shadow);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}
.hi-post-card:hover {
  box-shadow: 0 4px 12px var(--hi-card-shadow-hover);
  transform: translateY(-1px);
}

.hi-post-meta {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 0.35rem;
}

.hi-post-date {
  font-size: 0.78rem;
  color: var(--hi-text-date);
}

.hi-post-cat {
  font-size: 0.72rem;
  font-weight: 500;
  background: var(--hi-cat-badge-bg);
  color: var(--hi-cat-badge-color);
  padding: 0.1em 0.55em;
  border-radius: 3px;
}

.hi-post-title {
  font-size: 1rem;
  font-weight: 600;
  margin: 0 0 0.35rem;
  line-height: 1.4;
}
.hi-post-title a {
  color: var(--hi-text-primary);
  text-decoration: none;
  transition: color 0.15s;
}
.hi-post-title a:hover { color: var(--hi-accent); }

.hi-post-excerpt {
  font-size: 0.875rem;
  color: var(--hi-text-secondary);
  line-height: 1.6;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Divider ────────────────────────────────────────────────────── */
.hi-hr {
  border: none;
  border-top: 1px solid var(--hi-divider);
  margin: 2rem 0;
}

/* ── Tag browse ─────────────────────────────────────────────────── */
.hi-tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.hi-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.3em;
  padding: 0.3em 0.85em;
  background: var(--hi-tag-bg);
  color: var(--hi-tag-color);
  border: 1px solid var(--hi-tag-border);
  border-radius: 20px;
  font-size: 0.82rem;
  font-weight: 500;
  text-decoration: none;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.hi-tag:hover {
  background: var(--hi-accent);
  color: #fff;
  border-color: var(--hi-accent);
}

.hi-tag-count {
  font-size: 0.72rem;
  opacity: 0.7;
}

/* ── Mobile ─────────────────────────────────────────────────────── */
@media (max-width: 600px) {
  .hi-post-card { padding: 0.85rem 1rem; }
}
</style>

<div class="hi-wrap">

  <!-- ── Section 1: Recent Posts ─────────────────────────────────── -->
  <div class="hi-section">
    <div class="hi-section-header">
      <h2 class="hi-section-title">Recent Posts</h2>
      <div class="hi-section-links">
        <a class="hi-section-link" href="<%= url_for('/archives/') %>">All Posts →</a>
      </div>
    </div>
    <div class="hi-posts-list">
      <% site.posts.sort('-date').limit(4).each(function(post) { %>
        <div class="hi-post-card">
          <div class="hi-post-meta">
            <span class="hi-post-date"><%= date(post.date, 'YYYY-MM-DD') %></span>
            <% if (post.categories.length > 0) { %>
              <span class="hi-post-cat"><%= post.categories.first().name %></span>
            <% } %>
          </div>
          <h3 class="hi-post-title">
            <a href="<%= url_for(post.path) %>" target="<%= theme.index.post_url_target %>"><%= post.title %></a>
          </h3>
          <% var excerpt = post.description || post.excerpt || post.content || '' %>
          <p class="hi-post-excerpt"><%- strip_html(excerpt).substring(0, 150).trim().replace(/\n/g, ' ') %></p>
        </div>
      <% }) %>
    </div>
  </div>

  <hr class="hi-hr">

  <!-- ── Section 2: Browse by Tag ────────────────────────────────── -->
  <div class="hi-section">
    <div class="hi-section-header">
      <h2 class="hi-section-title">Browse by Tag</h2>
      <div class="hi-section-links">
        <a class="hi-section-link" href="<%= url_for('/tags/') %>">All Tags →</a>
        <a class="hi-section-link" href="<%= url_for('/categories/') %>">Browse Categories →</a>
      </div>
    </div>
    <div class="hi-tags-wrap">
      <% site.tags.sort('name').each(function(tag) { %>
        <a class="hi-tag" href="<%= url_for(tag.path) %>">
          <%= tag.name %><span class="hi-tag-count">· <%= tag.length %></span>
        </a>
      <% }) %>
    </div>
  </div>

</div>
