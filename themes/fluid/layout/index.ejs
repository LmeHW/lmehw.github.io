<%
if (theme.index.slogan.enable) {
  page.subtitle = theme.index.slogan.text || config.subtitle || ''
}
page.banner_img = theme.index.banner_img
page.banner_img_height = theme.index.banner_img_height
page.banner_mask_alpha = theme.index.banner_mask_alpha
%>

<%
var recentPosts = page.posts
if (recentPosts && typeof recentPosts.limit === 'function') {
  recentPosts = recentPosts.limit(4)
}
%>

<div class="home-recent-header">
  <h2 class="home-recent-title">Recent Blog</h2>
  <p class="home-recent-subtitle">Latest 4 posts</p>
</div>

<% recentPosts.each(function (post) { %>
  <div class="row mx-auto index-card">
    <% var post_url = url_for(post.path), index_img = post.index_img || theme.post.default_index_img %>
    <% if (index_img) { %>
      <div class="col-12 col-md-4 m-auto index-img">
        <a href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
          <img src="<%= url_for(index_img) %>" alt="<%= post.title %>">
        </a>
      </div>
    <% } %>
    <article class="col-12 col-md-<%= index_img ? '8' : '12' %> mx-auto index-info">
      <h2 class="index-header">
        <% if (theme.index.post_sticky && theme.index.post_sticky.enable && post.sticky > 0) { %>
          <i class="index-pin <%= theme.index.post_sticky && theme.index.post_sticky.icon %>" title="Pin on top"></i>
        <% } %>
        <a href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
          <%= post.title %>
        </a>
      </h2>

      <% var excerpt = post.description || post.excerpt || (theme.index.auto_excerpt.enable && !post.encrypt && post.content) %>
      <a class="index-excerpt <%= index_img ? '' : 'index-excerpt__noimg' %>" href="<%= post_url %>" target="<%- theme.index.post_url_target %>">
        <div>
          <%- strip_html(excerpt).substring(0, 200).trim().replace(/\n/g, ' ') %>
        </div>
      </a>

      <div class="index-btm post-metas">
        <% if (theme.index.post_meta.date) { %>
          <div class="post-meta mr-3">
            <i class="iconfont icon-date"></i>
            <time datetime="<%= full_date(post.date, 'YYYY-MM-DD HH:mm') %>" pubdate>
              <%- date(post.date, config.date_format) %>
            </time>
          </div>
        <% } %>
        <% if (theme.index.post_meta.category && post.categories.length > 0) { %>
          <div class="post-meta mr-3 d-flex align-items-center">
            <i class="iconfont icon-category"></i>
            <%- partial('_partials/category-chains', { categories: post.categories, limit: 1 }) %>
          </div>
        <% } %>
        <% if (theme.index.post_meta.tag && post.tags.length > 0) { %>
          <div class="post-meta">
            <i class="iconfont icon-tags"></i>
            <% post.tags.each(function(tag){ %>
              <a href="<%= url_for(tag.path) %>">#<%- tag.name %></a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </article>
  </div>
<% }) %>

<%- partial('_partials/paginator') %>

<style>
.home-recent-header {
  margin: 0 0 1rem;
  padding-bottom: 0.55rem;
  border-bottom: 1px solid var(--line-color, #d0d7de);
}

.home-recent-title {
  margin: 0;
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-color, #2f4154);
  letter-spacing: 0.01em;
}

.home-recent-subtitle {
  margin: 0.22rem 0 0;
  font-size: 0.82rem;
  color: var(--sec-text-color, #5c6b77);
}

.home-explore {
  margin-top: 3.25rem;
}

.home-explore-heading {
  font-size: 1.8rem;
  font-weight: 700;
  margin: 0 0 0.65rem;
  color: var(--text-color, #2f4154);
}

.home-explore-intro {
  margin: 0 0 1.1rem;
  color: var(--sec-text-color, #5c6b77);
  line-height: 1.75;
}

.home-explore-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.9rem;
  margin: 0 0 1.35rem;
}

.home-explore-link {
  color: var(--link-color, #1d4ed8);
  text-decoration: none;
}

.home-explore-link:hover {
  text-decoration: underline;
}

.home-explore-modes {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.28rem;
  border-radius: 12px;
  border: 1px solid var(--line-color, #d0d7de);
  background: color-mix(in srgb, var(--board-bg-color, #fff) 82%, var(--line-color, #d0d7de) 18%);
  margin-bottom: 0.95rem;
}

.ex-mode-btn {
  appearance: none;
  border: none;
  border-radius: 9px;
  padding: 0.38rem 0.78rem;
  font-size: 0.86rem;
  line-height: 1.2;
  font-weight: 600;
  color: var(--sec-text-color, #5c6b77);
  background: transparent;
  cursor: pointer;
  transition: background-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
}

.ex-mode-btn:hover {
  color: var(--text-color, #2f4154);
}

.ex-mode-btn.is-active {
  color: var(--text-color, #2f4154);
  background: var(--board-bg-color, #fff);
  box-shadow: 0 1px 0 rgba(15, 23, 42, 0.05), 0 1px 6px rgba(15, 23, 42, 0.08);
}

html[data-user-color-scheme='dark'] .ex-mode-btn.is-active {
  color: #dbeafe;
  background: rgba(96, 165, 250, 0.22);
  box-shadow: inset 0 0 0 1px rgba(147, 197, 253, 0.35);
}

.ex-mode-btn:focus-visible {
  outline: 2px solid var(--link-hover-color, #1e40af);
  outline-offset: 2px;
}

.home-explore-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-bottom: 1rem;
}

.ex-pill {
  appearance: none;
  border: 1px solid var(--line-color, #d0d7de);
  background: var(--board-bg-color, #fff);
  color: var(--sec-text-color, #5c6b77);
  border-radius: 999px;
  padding: 0.36rem 0.88rem;
  font-size: 0.9rem;
  line-height: 1.1;
  cursor: pointer;
  transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
}

.ex-pill:hover {
  border-color: var(--link-color, #1d4ed8);
  color: var(--link-color, #1d4ed8);
}

.ex-pill.is-active {
  background: var(--link-color, #1d4ed8);
  border-color: var(--link-color, #1d4ed8);
  color: #fff;
}

.ex-pill:focus-visible {
  outline: 2px solid var(--link-hover-color, #1e40af);
  outline-offset: 2px;
}

.ex-pill-count {
  opacity: 0.7;
}

.home-explore-status {
  margin: 0 0 1rem;
  color: var(--sec-text-color, #5c6b77);
  font-size: 0.95rem;
}

.home-explore-results {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.ex-card {
  display: block;
  border: 1px solid var(--line-color, #d0d7de);
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  background: var(--board-bg-color, #fff);
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.ex-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
  border-color: var(--link-color, #1d4ed8);
}

.ex-card.is-hidden {
  display: none;
}

.ex-card-img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}

.ex-card-body {
  padding: 0.82rem 0.92rem 0.9rem;
}

.ex-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.6rem;
  margin-bottom: 0.52rem;
}

.ex-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  font-size: 0.72rem;
  line-height: 1;
  font-weight: 600;
  letter-spacing: 0.01em;
  padding: 0.28rem 0.56rem;
}

.ex-badge-blog {
  background: rgba(29, 78, 216, 0.12);
  color: #1d4ed8;
}

html[data-user-color-scheme='dark'] .ex-badge-blog {
  background: rgba(96, 165, 250, 0.2);
  /* color: #93c5fd; */
  color: #1c59ff;
}

.ex-badge-project {
  background: rgba(245, 158, 11, 0.2);
  color: #b45309;
}

html[data-user-color-scheme='dark'] .ex-badge-project {
  background: rgba(251, 191, 36, 0.2);
  color: #fbbf24;
}

.ex-card-date {
  font-size: 0.74rem;
  color: var(--sec-text-color, #5c6b77);
}

.ex-card-title {
  margin: 0 0 0.4rem;
  font-size: 1rem;
  line-height: 1.45;
  color: var(--text-color, #2f4154);
}

.ex-card-desc {
  margin: 0 0 0.62rem;
  font-size: 0.88rem;
  line-height: 1.62;
  color: var(--sec-text-color, #5c6b77);
}

.ex-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.ex-card-tag {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  border: 1px solid var(--line-color, #d0d7de);
  padding: 0.14rem 0.48rem;
  font-size: 0.72rem;
  color: var(--sec-text-color, #5c6b77);
}

@media (max-width: 767.98px) {
  .home-explore {
    margin-top: 2.4rem;
  }

  .home-explore-results {
    grid-template-columns: 1fr;
  }
}

@media (min-width: 768px) and (max-width: 991.98px) {
  .home-explore-results {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
</style>

<%
  var explorePosts = site.posts.sort('-date');
  var isTypeTag = function(tagName) {
    var lowered = String(tagName || '').toLowerCase();
    return lowered === 'blog' || lowered === 'projects' || lowered === 'project';
  };
  var rawExploreProjects = site.data.home_explore_projects || [];
  var exploreProjects = rawExploreProjects.map(function(project) {
    var normalizedTags = Array.isArray(project.tags) ? project.tags.filter(function(tagName) {
      return isTypeTag(tagName) === false;
    }) : [];
    var normalizedCategories = Array.isArray(project.categories) ? project.categories : [];
    return {
      title: project.title || 'Untitled Project',
      url: project.url ? url_for(project.url) : url_for('/projects/'),
      img: project.img ? url_for(project.img) : '',
      date: project.date || '',
      desc: project.desc || '',
      tags: normalizedTags,
      categories: normalizedCategories
    };
  });
%>

<section class="home-explore">
  <h2 class="home-explore-heading">Explore</h2>
  <p class="home-explore-intro">Browse all posts and projects by tag or category.</p>

  <div class="home-explore-modes" id="home-explore-modes">
    <button class="ex-mode-btn is-active" type="button" data-mode="tag">Tag</button>
    <button class="ex-mode-btn" type="button" data-mode="category">Category</button>
  </div>

  <div class="home-explore-filters" id="home-explore-tags">
  </div>

  <p class="home-explore-status" id="home-explore-status">Showing all items.</p>

  <div class="home-explore-results" id="home-explore-results">
    <% explorePosts.each(function(post) { %>
      <% var explorePostUrl = url_for(post.path) %>
      <% var explorePostImg = post.index_img || theme.post.default_index_img %>
      <% var explorePostTags = post.tags.map(function(tag) { return tag.name }).filter(function(tagName) { return isTypeTag(tagName) === false }) %>
      <% var explorePostCategories = post.categories.map(function(category) { return category.name }) %>
      <a class="ex-card" href="<%= explorePostUrl %>" target="<%- theme.index.post_url_target %>" data-tags="<%= explorePostTags.map(function(tagName) { return encodeURIComponent(tagName) }).join(' ') %>" data-categories="<%= explorePostCategories.map(function(categoryName) { return encodeURIComponent(categoryName) }).join(' ') %>">
        <% if (explorePostImg) { %>
          <img class="ex-card-img" src="<%= url_for(explorePostImg) %>" alt="<%= post.title %>" loading="lazy">
        <% } %>
        <div class="ex-card-body">
          <div class="ex-card-top">
            <span class="ex-badge ex-badge-blog">Blog</span>
            <span class="ex-card-date"><%- date(post.date, config.date_format) %></span>
          </div>
          <h3 class="ex-card-title"><%= post.title %></h3>
          <% var explorePostExcerpt = post.description || post.excerpt || (theme.index.auto_excerpt.enable && post.encrypt !== true && post.content) %>
          <p class="ex-card-desc">
            <%- strip_html(explorePostExcerpt).substring(0, 140).trim().replace(/\n/g, ' ') %>
          </p>
          <% if (explorePostTags.length > 0) { %>
            <div class="ex-card-tags">
              <% explorePostTags.slice(0, 3).forEach(function(tagName){ %>
                <span class="ex-card-tag"><%- tagName %></span>
              <% }) %>
            </div>
          <% } %>
        </div>
      </a>
    <% }) %>

    <% exploreProjects.forEach(function(project) { %>
      <a class="ex-card" href="<%= project.url %>" data-tags="<%= project.tags.map(function(tagName) { return encodeURIComponent(tagName) }).join(' ') %>" data-categories="<%= project.categories.map(function(categoryName) { return encodeURIComponent(categoryName) }).join(' ') %>">
        <% if (project.img) { %>
          <img class="ex-card-img" src="<%= project.img %>" alt="<%= project.title %>" loading="lazy">
        <% } %>
        <div class="ex-card-body">
          <div class="ex-card-top">
            <span class="ex-badge ex-badge-project">Project</span>
            <span class="ex-card-date"><%= project.date %></span>
          </div>
          <h3 class="ex-card-title"><%= project.title %></h3>
          <p class="ex-card-desc"><%= project.desc %></p>
          <% if (project.tags.length > 0) { %>
            <div class="ex-card-tags">
              <% project.tags.slice(0, 4).forEach(function(tagName) { %>
                <span class="ex-card-tag"><%= tagName %></span>
              <% }) %>
            </div>
          <% } %>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<script>
  (function() {
    var modeBar = document.getElementById('home-explore-modes');
    var tagBar = document.getElementById('home-explore-tags');
    var status = document.getElementById('home-explore-status');
    var cards = Array.prototype.slice.call(document.querySelectorAll('#home-explore-results .ex-card'));
    var currentMode = 'tag';
    var currentValue = '';

    if (modeBar === null || tagBar === null || status === null || cards.length === 0) return;

    function decodeTag(tag) {
      if (tag === undefined || tag === null || tag === '') return '';
      try {
        return decodeURIComponent(tag);
      } catch (error) {
        return tag;
      }
    }

    function getCardValues(card, mode) {
      var source = mode === 'category' ? card.dataset.categories : card.dataset.tags;
      return (source || '').split(' ').filter(Boolean);
    }

    function getCountMap(mode) {
      var countMap = {};
      cards.forEach(function(card) {
        getCardValues(card, mode).forEach(function(encodedValue) {
          countMap[encodedValue] = (countMap[encodedValue] || 0) + 1;
        });
      });
      return countMap;
    }

    function renderFilterBar(mode) {
      var countMap = getCountMap(mode);
      var totalCount = cards.length;
      var sortedValues = Object.keys(countMap).sort(function(a, b) {
        if (countMap[b] !== countMap[a]) return countMap[b] - countMap[a];
        return decodeTag(a).localeCompare(decodeTag(b));
      });

      tagBar.innerHTML = '';

      var allButton = document.createElement('button');
      allButton.className = 'ex-pill';
      allButton.type = 'button';
      allButton.dataset.value = '';
      allButton.dataset.label = 'All';
      allButton.innerHTML = 'All <span class="ex-pill-count">· ' + totalCount + '</span>';
      tagBar.appendChild(allButton);

      sortedValues.forEach(function(encodedValue) {
        var label = decodeTag(encodedValue);
        var button = document.createElement('button');
        button.className = 'ex-pill';
        button.type = 'button';
        button.dataset.value = encodedValue;
        button.dataset.label = label;
        button.innerHTML = label + ' <span class="ex-pill-count">· ' + countMap[encodedValue] + '</span>';
        tagBar.appendChild(button);
      });
    }

    function applyFilter(value, label) {
      var visibleCount = 0;
      var activeLabel = label || decodeTag(value) || 'All';

      Array.prototype.forEach.call(tagBar.querySelectorAll('.ex-pill'), function(button) {
        button.classList.toggle('is-active', (button.dataset.value || '') === value);
      });

      cards.forEach(function(card) {
        var values = getCardValues(card, currentMode);
        var show = (value === '' || values.indexOf(value) !== -1);
        card.classList.toggle('is-hidden', show === false);
        if (show === true) visibleCount += 1;
      });

      if (value === '') {
        status.textContent = 'Showing all items (' + visibleCount + ') by ' + currentMode + '.';
        return;
      }

      status.textContent = visibleCount > 0
        ? 'Showing ' + visibleCount + ' item' + (visibleCount > 1 ? 's' : '') + ' by ' + currentMode + ' "' + activeLabel + '".'
        : 'No items found for ' + currentMode + ' "' + activeLabel + '".';
    }

    tagBar.addEventListener('click', function(event) {
      var button = event.target.closest('.ex-pill');
      if (button === null) return;
      currentValue = button.dataset.value || '';
      applyFilter(currentValue, button.dataset.label || '');
    });

    modeBar.addEventListener('click', function(event) {
      var button = event.target.closest('.ex-mode-btn');
      if (button === null) return;
      currentMode = button.dataset.mode || 'tag';
      currentValue = '';
      Array.prototype.forEach.call(modeBar.querySelectorAll('.ex-mode-btn'), function(modeButton) {
        modeButton.classList.toggle('is-active', modeButton.dataset.mode === currentMode);
      });
      renderFilterBar(currentMode);
      applyFilter('', 'All');
    });

    renderFilterBar(currentMode);
    applyFilter('', 'All');
  })();
</script>
